# Google Gemini API key (required)
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key

# Pinecone API key (required)
# Get one at: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key

# Pinecone index name (optional, default: rag-llm-index)
PINECONE_INDEX_NAME=rag-llm-index

# Pinecone cloud provider (optional, default: aws)
PINECONE_CLOUD=aws

# Pinecone region (optional, default: us-east-1)
PINECONE_REGION=us-east-1

# Path to the source PDF (optional, default: data.pdf)
PDF_PATH=data.pdf
